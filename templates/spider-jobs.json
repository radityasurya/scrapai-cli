{
  "name": "example_jobs",
  "source_url": "https://jobs.example.com",
  "allowed_domains": ["jobs.example.com"],
  "start_urls": ["https://jobs.example.com/listings"],
  "rules": [
    {
      "allow": ["/job/\\d+"],
      "callback": "parse_job",
      "follow": false
    }
  ],
  "settings": {
    "JOB_CUSTOM_SELECTORS": {
      "title": "h1.job-title",
      "company": "span.company-name",
      "location": "span.location",
      "description": "div.job-description"
    }
  }
}
