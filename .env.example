# ScrapAI Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Data directory - where all scraped data, analysis, and artifacts are stored
DATA_DIR=./data

# Database connection string
# Default: SQLite (no setup required, perfect for getting started)
# For production/scale: use PostgreSQL (postgresql://user:password@localhost:5432/scrapai)
DATABASE_URL=sqlite:///scrapai.db

# Logging
# LOG_LEVEL=info
# LOG_DIR=./logs

# =============================================================================
# API CONFIGURATION (for REST API)
# =============================================================================

# API server settings
API_HOST=0.0.0.0
API_PORT=8481
API_WORKERS=4

# Security - Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# REDIS CONFIGURATION (for API rate limiting, webhooks, background jobs)
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_PREFIX=scrapai:api

# =============================================================================
# PROXY CONFIGURATION (SmartProxyMiddleware)
# =============================================================================

# ScrapAI automatically uses proxies when needed (on 403/429 errors)
# and learns which domains require them. Uncomment and fill in your proxy
# details to enable.

# Datacenter Proxy (recommended for most use cases - faster, cheaper)
# DATACENTER_PROXY_USERNAME=your_username
# DATACENTER_PROXY_PASSWORD=your_password
# DATACENTER_PROXY_HOST=your-datacenter-proxy.com
# DATACENTER_PROXY_PORT=10000  # Port 10000 = rotating IPs (recommended)

# Residential Proxy (used with --proxy-type residential flag)
# Use for sites that block datacenter IPs
# RESIDENTIAL_PROXY_USERNAME=your_username
# RESIDENTIAL_PROXY_PASSWORD=your_password
# RESIDENTIAL_PROXY_HOST=your-residential-proxy.com
# RESIDENTIAL_PROXY_PORT=7000  # Port 7000 = rotating residential IPs

# =============================================================================
# S3-COMPATIBLE OBJECT STORAGE (optional)
# =============================================================================

# If these are set, scraped data will be automatically uploaded to S3
# Works with: Hetzner, DigitalOcean Spaces, Wasabi, Backblaze, AWS S3, etc.
# S3_ACCESS_KEY=your_access_key_here
# S3_SECRET_KEY=your_secret_key_here
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_BUCKET=your-bucket-name

# =============================================================================
# AIRFLOW CONFIGURATION (for docker-compose.airflow.yml)
# =============================================================================

# SECURITY: You MUST change these credentials before deploying!
# The docker-compose setup will fail to start if these are not set explicitly.
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
AIRFLOW_UID=501

# Airflow-specific ScrapAI settings (optional)
# SCRAPAI_CLI_PATH=/path/to/scrapai/cli
# AIRFLOW_PROJECT_FILTER=my-project  # Only run DAGs for this project

# =============================================================================
# POSTGRESQL FALLBACK (alternative to DATABASE_URL)
# =============================================================================

# If DATABASE_URL is not set, Alembic will use these individual settings
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=scrapai
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
